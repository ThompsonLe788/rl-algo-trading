# ================================================================
# ATS XAU/USD — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ================================================================

# --- Telegram Alerts (optional) ---
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=123456789:ABCdefGHI-your-bot-token-here

# Get chat ID: message your bot then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=123456789

# --- MT5 Files Path (optional) ---
# Only needed if your MT5 is installed in a non-default location.
# Default: %APPDATA%\MetaQuotes\Terminal\Common\Files
# MT5_FILES_PATH=C:\Users\YourName\AppData\Roaming\MetaQuotes\Terminal\Common\Files
